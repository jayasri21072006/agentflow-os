        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"Classify this query into exactly one word only.\\nChoose from: analytics, crm, meeting, project, comms, executive.\\nIf the query is about company overview, KPIs, strategy, performance summary, or needs multiple departments, classify as executive.\\nReply with the single word only. No punctuation. No explanation.\\n\\nQuery: {{$json.body.query}}\"\n        }\n      ]\n    }\n  ]\n}",
