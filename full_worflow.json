    {
      "parameters": {
        "jsCode": "const raw = $input.item.json.candidates?.[0]?.content?.parts?.[0]?.text || \"\";\n\n// clean intent\nlet intent = raw.trim().toLowerCase().replace(/[^a-z]/g, '');\n\n// allowed intents\nconst allowed = [\"analytics\",\"crm\",\"meeting\",\"project\",\"comms\",\"executive\"];\n\n// fallback if not matching\nif (!allowed.includes(intent)) {\n  intent = \"analytics\";\n}\n\nreturn {\n  json: {\n    intent,\n    debug_raw: raw,\n    debug_cleaned: intent,\n    original_query: $('Webhook').item.json.body.query,\n    context: $('Webhook').item.json.body.context || ''\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
