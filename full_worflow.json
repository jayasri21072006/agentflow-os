        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [{\n    \"parts\": [{\n      \"text\": \"You are an Analytics Agent. Analyze business metrics and return structured insights.\\n\\nRespond ONLY with valid JSON (no markdown, no backticks):\\n{\\n  \\\"summary\\\": \\\"one sentence summary\\\",\\n  \\\"insights\\\": [\\\"insight1\\\", \\\"insight2\\\"],\\n  \\\"anomalies\\\": [\\\"anomaly1\\\"],\\n  \\\"recommendations\\\": [\\\"rec1\\\", \\\"rec2\\\"],\\n  \\\"kpis\\\": {\\\"revenue_trend\\\": \\\"up/down/stable\\\", \\\"key_metric\\\": \\\"value\\\"}\\n}\\n\\nQuery: {{$('Webhook').item.json.body.query}}\\nContext: {{$('Webhook').item.json.body.context}}\"\n    }]\n  }]\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        -752,
        400
      ],
      "id": "c97192ee-e15d-4e78-a45c-e93d844178fb",
      "name": "Analytics Agent"
    },
    {
      "parameters": {
        "jsCode": "function parseGemini(raw) {\n  try {\n    const m = raw.match(/```json\\n?([\\s\\S]*?)\\n?```/);\n    return m ? JSON.parse(m[1]) : JSON.parse(raw);\n  } catch(e) { return { raw_response: raw }; }\n}\nconst raw = $input.item.json.candidates[0].content.parts[0].text;\nreturn { json: { agent: 'analytics', status: 'success', timestamp: new Date().toISOString(), query: $('Webhook').item.json.body.query, result: parseGemini(raw) } };"
